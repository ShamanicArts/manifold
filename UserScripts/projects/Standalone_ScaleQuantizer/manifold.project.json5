{
  "name": "Standalone Scale Quantizer",
  "version": 1,
  "description": "Standalone MIDI scale quantizer export target",
  "ui": {
    "root": "ui/main.ui.lua",
    "sharedShell": false
  },
  "plugin": {
    "midiEffect": true,
    "runtimeFamily": "midi_effect",
    "view": {
      "defaultMode": "compact",
      "compact": {
        "w": 236,
        "h": 176
      },
      "split": {
        "w": 236,
        "h": 176
      }
    },
    "osc": {
      "enabled": true,
      "queryEnabled": true,
      "basePort": 9050,
      "oscQueryPort": 9051
    },
    "params": [
      {
        "path": "/plugin/params/root",
        "internalPath": "/midi/synth/rack/scale_quantizer/1/root",
        "type": "f",
        "min": 0,
        "max": 11,
        "default": 0,
        "hostParamId": "root",
        "hostParamName": "Root",
        "hostParamKind": "choice",
        "choices": [
          "C",
          "C#",
          "D",
          "D#",
          "E",
          "F",
          "F#",
          "G",
          "G#",
          "A",
          "A#",
          "B"
        ],
        "description": "Scale root note"
      },
      {
        "path": "/plugin/params/scale",
        "internalPath": "/midi/synth/rack/scale_quantizer/1/scale",
        "type": "f",
        "min": 1,
        "max": 6,
        "default": 1,
        "hostParamId": "scale",
        "hostParamName": "Scale",
        "hostParamKind": "choice",
        "choices": [
          "Major",
          "Minor",
          "Dorian",
          "Mixolydian",
          "Pentatonic",
          "Chromatic"
        ],
        "description": "Scale selection"
      },
      {
        "path": "/plugin/params/direction",
        "internalPath": "/midi/synth/rack/scale_quantizer/1/direction",
        "type": "f",
        "min": 1,
        "max": 3,
        "default": 1,
        "hostParamId": "direction",
        "hostParamName": "Direction",
        "hostParamKind": "choice",
        "choices": [
          "Nearest",
          "Up",
          "Down"
        ],
        "description": "Scale quantization direction"
      }
    ]
  },
  "dsp": {
    "default": "dsp/main.lua"
  },
  "theme": "../Main/themes/dark.lua"
}
