{
  "version": 1,
  "name": "Manifold Scale Quantizer",
  "root": {
    "id": "standalone_scale_quantizer_remote",
    "type": "panel",
    "x": 0,
    "y": 0,
    "w": 236,
    "h": 176,
    "style": {
      "bg": "#0b1220",
      "border": "#1f2b4d",
      "borderWidth": 1,
      "radius": 0
    },
    "children": [
      { "id": "header_bg", "type": "panel", "x": 0, "y": 0, "w": 236, "h": 12, "style": { "bg": "#111827", "borderWidth": 0, "radius": 0 } },
      { "id": "header_accent", "type": "panel", "x": 0, "y": 0, "w": 18, "h": 12, "style": { "bg": "#4ade80", "borderWidth": 0, "radius": 0 } },
      { "id": "title", "type": "label", "x": 24, "y": 0, "w": 150, "h": 12, "text": "Scale Quantizer", "style": { "color": "#ffffff", "fontSize": 9 } },
      { "id": "root", "type": "dropdown", "x": 12, "y": 26, "w": 64, "h": 20, "label": "Root", "bind": { "path": "/plugin/params/root" } },
      { "id": "scale", "type": "dropdown", "x": 84, "y": 26, "w": 140, "h": 20, "label": "Scale", "bind": { "path": "/plugin/params/scale" } },
      { "id": "direction", "type": "dropdown", "x": 12, "y": 54, "w": 212, "h": 20, "label": "Direction", "bind": { "path": "/plugin/params/direction" } }
    ]
  }
}
