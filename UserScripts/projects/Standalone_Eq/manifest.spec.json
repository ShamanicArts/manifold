{
  "name": "Standalone EQ8",
  "version": 1,
  "description": "8-band parametric EQ export target",
  "ui": {
    "root": "ui/main.ui.lua",
    "sharedShell": false
  },
  "plugin": {
    "view": {
      "defaultMode": "split",
      "compact": { "w": 236, "h": 220 },
      "split": { "w": 472, "h": 220 }
    },
    "osc": {
      "enabled": true,
      "queryEnabled": true,
      "basePort": 9020,
      "oscQueryPort": 9021
    },
    "paramsSpec": {
      "generator": "eq8_single",
      "publicPathBase": "/plugin/params",
      "internalPathBase": "/midi/synth/rack/eq/1"
    }
  },
  "dsp": {
    "default": "dsp/main.lua"
  },
  "theme": "../Main/themes/dark.lua"
}
