#!/usr/bin/env python3
"""
Comprehensive test suite for all looper backend behaviors.
Tests: layer selection, forward recording, retrospective at various bar sizes,
overdub, clear all, stop playback, and audio content verification.
"""

import socket
import json
import time
import glob
import sys
import wave
import struct
import math
import os


class LooperTestClient:
    def __init__(self):
        sockets = sorted(glob.glob("/tmp/manifold_*.sock"))
        if not sockets:
            print("ERROR: No looper process found. Start LooperHeadless first.", file=sys.stderr)
            sys.exit(1)
        self.sock_path = sockets[-1]
        self.passed = 0
        self.failed = 0
        self.errors = []

    def cmd(self, command):
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.connect(self.sock_path)
        s.sendall((command + "\n").encode())
        s.settimeout(2.0)
        resp = ""
        try:
            while True:
                d = s.recv(65536)
                if not d:
                    break
                resp += d.decode()
                if "\n" in resp:
                    break
        except socket.timeout:
            pass
        s.close()
        return resp.strip()

    def state(self):
        r = self.cmd("STATE")
        return json.loads(r[3:]) if r.startswith("OK {") else r

    def wait_injection(self, timeout=5.0):
        deadline = time.time() + timeout
        while time.time() < deadline:
            time.sleep(0.1)
            r = self.cmd("INJECTION_STATUS")
            if '"active":false' in r:
                return True
        return False

    def check(self, name, condition, detail=""):
        if condition:
            print(f"  PASS: {name}")
            self.passed += 1
        else:
            msg = f"  FAIL: {name}"
            if detail:
                msg += f" -- {detail}"
            print(msg)
            self.failed += 1
            self.errors.append(name)

    def reset(self):
        for i in range(4):
            self.cmd(f"LAYER {i} CLEAR")
            self.cmd(f"LAYER {i} SPEED 1.0")
            self.cmd(f"LAYER {i} REVERSE 0")
            self.cmd(f"LAYER {i} VOLUME 1.0")
        self.cmd("LAYER 0")
        self.cmd("TEMPO 120")
        self.cmd("TARGETBPM 120")
        self.cmd("MODE firstLoop")
        self.cmd("VOLUME 1.0")
        time.sleep(0.2)


def generate_test_wav(filepath, duration_secs, freq=440, sample_rate=44100):
    n = int(sample_rate * duration_secs)
    with wave.open(filepath, "w") as w:
        w.setnchannels(1)
        w.setsampwidth(2)
        w.setframerate(sample_rate)
        for i in range(n):
            t = i / sample_rate
            env = min(1.0, t * 20) * min(1.0, (duration_secs - t) * 20)
            sample = 0.5 * env * math.sin(2 * math.pi * freq * t)
            w.writeframes(struct.pack("<h", int(sample * 32767)))
    return n


