def main():
    # Generate test files with different frequencies
    print("Generating test audio files...")
    generate_test_wav("/tmp/looper_test_4s.wav", 4.0, freq=440)
    generate_test_wav("/tmp/looper_test_2s.wav", 2.0, freq=440)
    generate_test_wav("/tmp/looper_test_440hz.wav", 2.0, freq=440)
    generate_test_wav("/tmp/looper_test_660hz.wav", 2.0, freq=660)
    
    c = LooperTestClient()
    print(f"Connected to {c.sock_path}\n")
    
    # Run all tests
    test_layer_selection_and_commit(c)
    test_retrospective_various_bars(c)
    test_clear_all_layers(c)
    test_overdub(c)
    test_forward_record_to_layer(c)
    test_playback_stop(c)
    test_multiple_loops_playing(c)
    test_speed_affects_playback(c)
    test_reverse_playback(c)
    test_free_mode_record(c)
    
    # Summary
    print(f"\n{'=' * 50}")
    print(f"RESULTS: {c.passed} passed, {c.failed} failed")
    if c.errors:
        print(f"Failed: {', '.join(c.errors)}")
    print(f"{'=' * 50}")
    
    return 0 if c.failed == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
