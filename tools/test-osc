def test_ws_handshake(t):
    """Test WebSocket upgrade handshake."""
    print("=== Test: WebSocket - Handshake ===")
    ws = SimpleWebSocket()
    try:
        resp = ws.connect(timeout=5)
        t.check("ws handshake 101", "101" in resp, resp.split('\r\n')[0])
        t.check("ws Upgrade header", "Upgrade: websocket" in resp
                or "Upgrade: WebSocket" in resp, resp[:200])
        t.check("ws Sec-WebSocket-Accept present", "Sec-WebSocket-Accept" in resp)
        t.check("ws connected", ws.connected)
    except Exception as e:
        t.check("ws handshake succeeded", False, str(e))
    finally:
        ws.close()


def test_ws_ping_pong(t):
    """Test WebSocket ping/pong."""
    print("=== Test: WebSocket - Ping/Pong ===")
    ws = SimpleWebSocket()
    try:
        ws.connect(timeout=5)

        # Send ping with payload
        ws.send_ping(b'hello')

        # Expect pong with same payload
        opcode, payload = ws.recv_frame(timeout=3)
        t.check("pong received", opcode == 0xA, f"got opcode {opcode:#x}")
        t.check("pong payload matches", payload == b'hello',
                f"got {payload!r}")
    except Exception as e:
        t.check("ping/pong test", False, str(e))
    finally:
        ws.close()


def test_ws_close(t):
    """Test WebSocket graceful close."""
    print("=== Test: WebSocket - Graceful close ===")
    ws = SimpleWebSocket()
    try:
        ws.connect(timeout=5)

        # Send close frame
        ws.send_close(1000, 'goodbye')

        # Server should echo close frame
        opcode, payload = ws.recv_frame(timeout=3)
        t.check("close frame echoed", opcode == 0x8, f"got opcode {opcode:#x}")
    except Exception as e:
        t.check("graceful close test", False, str(e))
    finally:
        ws.close()


def test_ws_listen_tempo(t, cli):
    """Test LISTEN command for tempo value streaming."""
    print("=== Test: WebSocket - LISTEN tempo ===")
    cli.cmd("TEMPO 120")
    time.sleep(0.2)

    ws = SimpleWebSocket()
    try:
        ws.connect(timeout=5)

        # Subscribe to tempo
        listen_cmd = json.dumps({"COMMAND": "LISTEN", "DATA": "/looper/tempo"})
        ws.send_text(listen_cmd)
        time.sleep(0.2)

        # Change tempo via CLI to trigger a broadcast
        cli.cmd("TEMPO 133")
        time.sleep(0.5)  # wait for broadcast cycle (30Hz = ~33ms, give it a few cycles)

        # Read frames - should get a binary OSC packet with tempo value
        got_tempo = False
        received_value = None
        for _ in range(30):  # try reading up to 30 frames
            try:
                opcode, payload = ws.recv_frame(timeout=2)
                if opcode == 0x2:  # binary = OSC packet
                    addr, type_tag, args = parse_osc_message(payload)
                    if addr == '/looper/tempo' and len(args) > 0:
                        received_value = args[0]
                        if abs(args[0] - 133.0) < 1.0:
                            got_tempo = True
                            break
            except socket.timeout:
                break
            except Exception:
                break

        t.check("received tempo update via WS", got_tempo,
                f"value={received_value}" if received_value else "no binary frames received")

    except Exception as e:
        t.check("ws listen tempo test", False, str(e))
    finally:
        ws.close()
        cli.cmd("TEMPO 120")
        time.sleep(0.1)


