def test_osc_tempo(t, cli):
    """Test setting tempo via OSC UDP."""
    print("=== Test: OSC UDP - Set tempo ===")
    cli.cmd("TEMPO 120")
    time.sleep(0.2)

    send_osc('/looper/tempo', [('f', 145.0)])
    time.sleep(0.3)

    status, body = http_get('/osc/looper/tempo')
    t.check("http status 200", status == 200, status)
    data = json.loads(body)
    t.check("tempo changed to 145", abs(data.get("VALUE", 0) - 145.0) < 0.5,
            f"got {data.get('VALUE')}")

    # Restore
    cli.cmd("TEMPO 120")
    time.sleep(0.2)


