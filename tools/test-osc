class TestRunner:
    def __init__(self):
        self.passed = 0
        self.failed = 0
        self.errors = []

    def check(self, name, condition, detail=""):
        if condition:
            print(f"  PASS: {name}")
            self.passed += 1
        else:
            msg = f"  FAIL: {name}"
            if detail:
                msg += f" -- {detail}"
            print(msg)
            self.failed += 1
            self.errors.append(name)

    def summary(self):
        print(f"\n{'=' * 60}")
        print(f"RESULTS: {self.passed} passed, {self.failed} failed")
        if self.errors:
            print(f"Failed: {', '.join(self.errors)}")
        print(f"{'=' * 60}")
        return self.failed == 0


# ============================================================================
# OSC helpers
# ============================================================================

def pad4(n):
    """Round up to next multiple of 4."""
    return n + (4 - n % 4) % 4

def build_osc_message(address, args):
    """Build a raw OSC binary message.
    args is a list of (type_char, value) tuples:
      ('f', 1.0), ('i', 42), ('s', 'hello')
    """
    # Address (null-terminated, padded to 4)
    addr_bytes = address.encode('ascii') + b'\x00'
    addr_bytes += b'\x00' * (pad4(len(addr_bytes)) - len(addr_bytes))

    # Type tag string
    type_tag = ',' + ''.join(t for t, v in args)
    tt_bytes = type_tag.encode('ascii') + b'\x00'
    tt_bytes += b'\x00' * (pad4(len(tt_bytes)) - len(tt_bytes))

    # Arguments
    arg_bytes = b''
    for t, v in args:
        if t == 'f':
            arg_bytes += struct.pack('>f', float(v))
        elif t == 'i':
            arg_bytes += struct.pack('>i', int(v))
        elif t == 's':
            s = v.encode('ascii') + b'\x00'
            s += b'\x00' * (pad4(len(s)) - len(s))
            arg_bytes += s

    return addr_bytes + tt_bytes + arg_bytes

def parse_osc_message(data):
    """Parse an OSC binary message. Returns (address, type_tag, args)."""
    # Read address
    end = data.index(b'\x00')
    address = data[:end].decode('ascii')
    offset = pad4(end + 1)

    # Read type tag
    if data[offset:offset+1] != b',':
        return address, '', []
    end2 = data.index(b'\x00', offset)
    type_tag = data[offset+1:end2].decode('ascii')
    offset = pad4(end2 + 1)

    # Read arguments
    args = []
    for t in type_tag:
        if t == 'f':
            val = struct.unpack('>f', data[offset:offset+4])[0]
            args.append(val)
            offset += 4
        elif t == 'i':
            val = struct.unpack('>i', data[offset:offset+4])[0]
            args.append(val)
            offset += 4
        elif t == 's':
            end3 = data.index(b'\x00', offset)
            val = data[offset:end3].decode('ascii')
            offset = pad4(end3 + 1)
            args.append(val)
        elif t == 'N':
            args.append(None)

    return address, type_tag, args


def send_osc(address, args, port=OSC_PORT):
    """Send an OSC message via UDP."""
    msg = build_osc_message(address, args)
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.sendto(msg, ('127.0.0.1', port))
    sock.close()


# ============================================================================
# HTTP helpers
# ============================================================================

def http_get(path, port=OSCQUERY_PORT):
    """Simple HTTP GET, returns (status, body_string)."""
    conn = http.client.HTTPConnection('127.0.0.1', port, timeout=5)
    conn.request('GET', path)
    resp = conn.getresponse()
    body = resp.read().decode('utf-8')
    status = resp.status
    conn.close()
    return status, body

def http_post(path, body, port=OSCQUERY_PORT):
    """Simple HTTP POST, returns (status, body_string)."""
    conn = http.client.HTTPConnection('127.0.0.1', port, timeout=5)
    headers = {'Content-Type': 'text/plain', 'Content-Length': str(len(body))}
    conn.request('POST', path, body=body, headers=headers)
    resp = conn.getresponse()
    rbody = resp.read().decode('utf-8')
    status = resp.status
    conn.close()
    return status, rbody


# ============================================================================
# WebSocket helpers (minimal client implementation)
# ============================================================================

class SimpleWebSocket:
    """Minimal RFC 6455 WebSocket client for testing."""

    def __init__(self, host='127.0.0.1', port=OSCQUERY_PORT):
        self.host = host
        self.port = port
        self.sock = None
        self.connected = False

    def connect(self, timeout=5):
        """Perform WebSocket handshake."""
        self.sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.sock.settimeout(timeout)
        self.sock.connect((self.host, self.port))

        # Generate random key
        import random
        key_bytes = bytes(random.getrandbits(8) for _ in range(16))
        self.ws_key = base64.b64encode(key_bytes).decode('ascii')

        # Send upgrade request
        request = (
            f"GET / HTTP/1.1\r\n"
            f"Host: {self.host}:{self.port}\r\n"
            f"Upgrade: websocket\r\n"
            f"Connection: Upgrade\r\n"
            f"Sec-WebSocket-Key: {self.ws_key}\r\n"
            f"Sec-WebSocket-Version: 13\r\n"
            f"\r\n"
        )
        self.sock.sendall(request.encode('ascii'))

        # Read response
        response = b''
        while b'\r\n\r\n' not in response:
            chunk = self.sock.recv(4096)
            if not chunk:
                raise ConnectionError("Connection closed during handshake")
            response += chunk

        resp_str = response.decode('ascii', errors='replace')

        # Verify 101 Switching Protocols
        if '101' not in resp_str.split('\r\n')[0]:
            raise ConnectionError(f"Handshake failed: {resp_str.split(chr(13))[0]}")

        # Verify Sec-WebSocket-Accept
        expected_accept = self._compute_accept(self.ws_key)
        if expected_accept not in resp_str:
            raise ConnectionError(f"Invalid Sec-WebSocket-Accept. Expected: {expected_accept}")

        self.connected = True
        return resp_str

    def _compute_accept(self, key):
        """Compute expected Sec-WebSocket-Accept value."""
        magic = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
        h = hashlib.sha1((key + magic).encode('ascii')).digest()
        return base64.b64encode(h).decode('ascii')

    def send_text(self, text):
        """Send a text frame (masked, as client frames must be)."""
        self._send_frame(0x1, text.encode('utf-8'))

    def send_binary(self, data):
        """Send a binary frame (masked)."""
        self._send_frame(0x2, data)

    def send_ping(self, payload=b''):
        """Send a ping frame."""
        self._send_frame(0x9, payload)

    def send_close(self, code=1000, reason=''):
        """Send a close frame."""
        payload = struct.pack('>H', code) + reason.encode('utf-8')
        self._send_frame(0x8, payload)

    def _send_frame(self, opcode, payload):
        """Send a WebSocket frame with masking (client->server must be masked)."""
        import random
        frame = bytearray()

        # FIN=1, opcode
        frame.append(0x80 | opcode)

        # Payload length + mask bit
        length = len(payload)
        if length < 126:
            frame.append(0x80 | length)  # mask bit set
        elif length < 65536:
            frame.append(0x80 | 126)
            frame.extend(struct.pack('>H', length))
        else:
            frame.append(0x80 | 127)
            frame.extend(struct.pack('>Q', length))

        # Mask key (4 random bytes)
        mask = bytes(random.getrandbits(8) for _ in range(4))
        frame.extend(mask)

        # Masked payload
        masked = bytearray(len(payload))
        for i in range(len(payload)):
            masked[i] = payload[i] ^ mask[i % 4]
        frame.extend(masked)

        self.sock.sendall(bytes(frame))

    def recv_frame(self, timeout=5):
        """Read a single WebSocket frame. Returns (opcode, payload_bytes)."""
        self.sock.settimeout(timeout)

        # Read 2-byte header
        header = self._recv_exact(2)
        opcode = header[0] & 0x0F
        masked = (header[1] & 0x80) != 0
        length = header[1] & 0x7F

        if length == 126:
            ext = self._recv_exact(2)
            length = struct.unpack('>H', ext)[0]
        elif length == 127:
            ext = self._recv_exact(8)
            length = struct.unpack('>Q', ext)[0]

        mask_key = b''
        if masked:
            mask_key = self._recv_exact(4)

        payload = self._recv_exact(length) if length > 0 else b''

        if masked and mask_key:
            payload = bytearray(payload)
            for i in range(len(payload)):
                payload[i] ^= mask_key[i % 4]
            payload = bytes(payload)

        return opcode, payload

    def _recv_exact(self, n):
        """Read exactly n bytes."""
        buf = b''
        while len(buf) < n:
            chunk = self.sock.recv(n - len(buf))
            if not chunk:
                raise ConnectionError("Connection closed")
            buf += chunk
        return buf

    def close(self):
        if self.sock:
            try:
                self.send_close()
            except:
                pass
            try:
                self.sock.close()
            except:
                pass
        self.connected = False


# ============================================================================
# CLI socket helper (for changing state via the control protocol)
# ============================================================================

class LooperCLI:
    """Send commands via the Unix socket control protocol."""
    def __init__(self):
        sockets = sorted(glob.glob("/tmp/looper_*.sock"))
        if not sockets:
            print("ERROR: No looper process found. Start LooperHeadless first.", file=sys.stderr)
            sys.exit(1)
        self.sock_path = sockets[-1]

    def cmd(self, command):
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.connect(self.sock_path)
        s.sendall((command + "\n").encode())
        s.settimeout(2.0)
        resp = ""
        try:
            while True:
                d = s.recv(65536)
                if not d:
                    break
                resp += d.decode()
                if "\n" in resp:
                    break
        except socket.timeout:
            pass
        s.close()
        return resp.strip()


