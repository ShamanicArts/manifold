def test_ws_binary_osc_format(t, cli):
    """Verify the binary frames are valid OSC packets."""
    print("=== Test: WebSocket - Binary OSC format validation ===")
    cli.cmd("TEMPO 120")
    time.sleep(0.3)

    ws = SimpleWebSocket()
    try:
        ws.connect(timeout=5)
        ws.send_text(json.dumps({"COMMAND": "LISTEN", "DATA": "/looper/tempo"}))

        # Wait for initial cache diff to flush, then drain any frames
        time.sleep(0.5)
        for _ in range(20):
            try:
                ws.recv_frame(timeout=0.2)
            except:
                break

        # Now change tempo - the next frame we get should be the new value
        cli.cmd("TEMPO 99")
        time.sleep(0.5)

        validated = False
        for _ in range(30):
            try:
                opcode, payload = ws.recv_frame(timeout=2)
                if opcode == 0x2 and len(payload) > 0:
                    addr, type_tag, args = parse_osc_message(payload)
                    if addr == '/looper/tempo' and len(args) > 0 and abs(args[0] - 99.0) < 1.0:
                        t.check("osc address starts with /", addr.startswith('/'))
                        t.check("osc has type tag", len(type_tag) > 0, type_tag)
                        t.check("osc type tag is f", type_tag == 'f', type_tag)
                        t.check("osc arg is float", isinstance(args[0], float),
                                type(args[0]))
                        t.check("osc value ~99", abs(args[0] - 99.0) < 1.0,
                                args[0])
                        validated = True
                        break
            except socket.timeout:
                break
            except Exception as e:
                t.check("osc parse succeeded", False, str(e))
                break

        if not validated:
            t.check("received osc binary frame with value 99", False, "timeout or wrong value")

    except Exception as e:
        t.check("ws binary format test", False, str(e))
    finally:
        ws.close()
        cli.cmd("TEMPO 120")
        time.sleep(0.1)


