leById(moved, \"osc\")\n+ 77   local adsr = moduleById(moved, \"adsr\")\n+ 78   local filter = moduleById(moved, \"filter\")\n  79 \n  80   assertEqual(osc.col, 0, \"wide node repacks to row start\")\n  81   assertEqual(adsr.col, 2, \"narrow node shifted after wide node\")\n  82   assertEqual(filter.col, 3, \"tail node remains packed after reorder\")\n  83   assertEqual(osc.w, 2, \"wide node width preserved\")\n  84 end\n  85 \n  86 local function testFlowReorderWrapsAcrossRows()\n- 87   local nodes = {\n+ 87   local modules = {\n  88     { id = \"adsr\", row = 0, col = 0, w = 1, h = 1 },\n  89     { id = \"osc\", row = 0, col = 1, w = 2, h = 1 },\n  90     { id = \"filter\", row = 0, col = 3, w = 2, h = 1 },\n  91     { id = \"fx1\", row = 1, col = 0, w = 2, h = 1 },\n  92     { id = \"fx2\", row = 1, col = 2, w = 2, h = 1 },\n  93     { id = \"eq\", row = 1, col = 4, w = 1, h = 1 },\n  94   }\n- 95   local moved = Rack.moveNodeInFlow(nodes, \"eq\", 2, 5, 0)\n- 96   local adsr = nodeById(moved, \"adsr\")\n- 97   local eq = nodeById(moved, \"eq\")\n- 98   local osc = nodeById(moved, \"osc\")\n- 99   local filter = nodeById(moved, \"filter\")\n+ 95   local moved = Rack.moveNodeInFlow(modules, \"eq\", 2, 5, 0)\n+ 96   local adsr = moduleById(moved, \"adsr\")\n+ 97   local eq = moduleById(moved, \"eq\")\n+ 98   local osc = moduleById(moved, \"osc\")\n+ 99   local filter = moduleById(moved, \"filter\")\n 100 \n 101   assertEqual(adsr.row, 0, \"adsr remains in first row\")\n 102   assertEqual(eq.row, 0, \"eq wraps into first row after insert\")\n 103   assertEqual(eq.col, 1, \"eq placed after adsr in flow\")\n     ...\n 106   assertEqual(filter.row, 1, \"filter wraps to second row after overflow\")\n 107   assertEqual(filter.col, 0, \"filter becomes first item in wrapped second row\")\n 108 end\n 109 \n-110 local function testConnectionDescriptorShape()\n-111   local connection = Rack.makeConnectionDescriptor {\n+110 local function testRackConnectionShape()\n+111   local