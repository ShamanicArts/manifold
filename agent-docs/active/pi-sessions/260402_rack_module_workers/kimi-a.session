d\n 134 \n     ...\n 136   local state = Rack.sanitizeRackState {\n 137     viewMode = \"patch\",\n 138     densityMode = \"compact\",\n 139     utilityDock = { visible = false, mode = \"hidden\", heightMode = \"collapsed\" },\n-140     nodes = {\n+140     modules = {\n 141       { id = \"adsr\", row = 0, col = 0, w = 1, h = 1 },\n 142       { id = \"oscillator\", row = 0, col = 1, w = 2, h = 1 },\n 143     },\n 144   }\n 145   local text = Rack.serializeLuaLiteral(state)\n 146   assertEqual(state.viewMode, \"patch\", \"view mode preserved\")\n 147   assertEqual(state.utilityDock.mode, \"hidden\", \"dock mode preserved\")\n 148   assertTrue(text:match(\"viewMode\"), \"serialized rack state contains view mode\")\n-149   assertTrue(text:match(\"oscillator\"), \"serialized rack state contains node ids\")\n+149   assertTrue(text:match(\"oscillator\"), \"serialized rack state contains module ids\")\n 150 end\n 151 \n 152 local tests = {\n 153   testDefaultRackState,\n-154   testCellLevelOccupancyForTallNode,\n+154   testCellLevelOccupancyForTallModule,\n 155   testSameRowReorderPreservesSizes,\n 156   testWideNodeReorderPreservesPackedStrip,\n 157   testFlowReorderWrapsAcrossRows,\n-158   testConnectionDescriptorShape,\n+158   testRackConnectionShape,\n 159   testMidiSynthRackSeedData,\n 160   testRackStateSanitizeAndSerialize,\n 161 }\n 162 \n     ...","firstChangedLine":20},"isError":false,"timestamp":1775152763564}}
