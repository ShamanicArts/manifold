.hasConnection(connections, kind, fromNodeId, fromPortId, toNodeId, toPortId)\n  return hasConnectionEndpoints(connections, kind, fromNodeId, fromPortId, toNodeId, toPortId)\nend\n\nfunction M.audioRouteEdgeMask(connections)\n  local source = type(connections) == \"table\" and connections or {}\n  local mask = 0\n  local outgoing = {}\n  local function isTransparentNode(nodeId)\n    local spec = findNodeSpec(nodeId)\n    local meta = spec and spec.meta or nil\n    return type(meta) == \"table\" and meta.audioPassthrough == true\n  end\n  local realSources = {\n    oscillator = true,\n    filter = true,\n    fx1 = true,\n    fx2 = true,\n\n[475 more lines in file. Use offset=1060 to continue.]"}],"isError":false,"timestamp":1775153186375}}
