{"type":"message","id":"7dca1c81","parentId":"90467266","timestamp":"2026-04-02T17:56:29.887Z","message":{"role":"toolResult","toolCallId":"tool_z9HJ6zFgAIPhmYXQFfNo9Ill","toolName":"read","content":[{"type":"text","text":"\n  for i = 1, #nextConnections do\n    local conn = nextConnections[i]\n    if conn and conn.id ~= \"fx2_to_eq\" and conn.id ~= \"eq_to_output\" and conn.id ~= \"fx2_to_output\" then\n      kept[#kept + 1] = RackLayout.makeConnectionDescriptor(conn)\n    end\n  end\n\n  local routeMode = math.floor(tonumber(mode) or M.EQ_ROUTE_INSERTED)\n  if routeMode == M.EQ_ROUTE_INSERTED then\n    kept[#kept + 1] = canonicalAudioConnection(rackNodes, \"fx2_to_eq\")\n    kept[#kept + 1] = canonicalAudioConnection(rackNodes, \"eq_to_output\")\n  elseif routeMode == M.EQ_ROUTE_BYPASSED then\n    kept[#kept + 1] = canonicalAudioConnection(rackNodes, \"fx2_to_output\")\n  end\n\n  return M.normalizeConnections(kept, rackNodes)\nend\n\nfunction M.spliceNode(connections, nodes, nodeId)\n  local rackNodes = type(nodes) == \"table\" and RackLayout.cloneNodes(nodes) or M.defaultRackState().nodes\n  local nextConnections = M.normalizeConnections(connections, rackNodes)\n  local kept = {}\n  local incoming = {}\n  local outgoing = {}\n\n  for i = 1, #nextConnections do\n    local conn = nextConnections[i]\n    local from = conn and conn.from or nil\n    local to = conn and conn.to or nil\n    local isAudio = tostring(conn and conn.kind or \"\") == \"audio\"\n    local touchesNode = isAudio and ((type(from) == \"table\" and from.nodeId == nodeId) or (type(to) == \"table\" and to.nodeId == nodeId))\n\n    if touchesNode then\n      if type(to) == \"table\" and to.nodeId == nodeId then\n        incoming[#incoming + 1] = RackLayout.makeConnectionDescriptor(conn)\n      end\n      if type(from) == \"table\" and from.nodeId == nodeId then\n        outgoing[#outgoing + 1] = RackLayout.makeConnectionDescriptor(conn)\n      end\n    else\n      kept[#kept + 1] = RackLayout.makeConnectionDescriptor(conn)\n    end\n  end\n\n  for i = 1, #incoming do\n    local inc = incoming[i]\n    for j = 1, #outgoing do\n      local out = outgoing[j]\n      local fromEndpoint = rawAudioEndpoint(inc, false)\n      local toEndpoint = rawAudioEndpoint(out, true)\n      local sameEndpoint = fromEndpoint and toEndpoint\n        and fromEndpoint.nodeId == toEndpoint.nodeId\n        and fromEndpoint.portId == toEndpoint.portId\n      if fromEndpoint and toEndpoint and not sameEndpoint then\n        kept[#kept + 1] = makeAudioConnectionFromEndpoints(\n          rackNodes,\n          fromEndpoint,\n          toEndpoint,\n          tostring(fromEndpoint.nodeId) .. \"_to_\" .. tostring(toEndpoint.nodeId),\n          { source = \"splice\" }\n        )\n      end\n    end\n  end\n\n  return M.normalizeConnections(kept, rackNodes)\nend\n\nfunction M.insertNodeAtVisualSlot(connections, nodes, nodeId, sourceNodes)\n  local rackNodes = type(nodes) == \"table\" and RackLayout.cloneNodes(nodes) or M.defaultRackState().nodes\n  local spliceNodes = type(sourceNodes) == \"table\" and RackLayout.cloneNodes(sourceNodes) or rackNodes\n  local nodeInputPortId = firstAudioPortId(nodeId, \"input\")\n  local nodeOutputPortId = firstAudioPortId(nodeId, \"output\")\n  if nodeInputPortId == nil or nodeOutputPortId == nil then\n    return M.normalizeConnections(connections, rackNodes)\n  end\n\n  local ordered = orderedAudioFlowNodes(rackNodes)\n  local nodeIndex = nil\n  for i = 1, #ordered do\n    local node = ordered[i]\n    if node and node.id == nodeId then\n      nodeIndex = i\n      break\n    end\n  end\n  if nodeIndex == nil then\n    return M.normalizeConnections(connections, rackNodes)\n  end\n\n  local prevNode = nil\n  for i = nodeIndex - 1, 1, -1 do\n    local candidate = ordered[i]\n    if candidate\n      and firstAudioPortId(candidate.id, \"output\") ~= nil\n      and not isTransparentAudioNode(candidate.id) then\n      prevNode = candidate\n      break\n    end\n  end\n\n  local nextNode = nil\n  for i = nodeIndex + 1, #ordered do\n    local candidate = ordered[i]\n    if candidate\n      and firstAudioPortId(candidate.id, \"input\") ~= nil\n      and not isTransparentAudioNode(candidate.id) then\n      nextNode = candidate\n      break\n    end\n  end\n\n  local prevOutputPortId = prevNode and firstAudioPortId(prevNode.id, \"output\") or nil\n  local nextInputPortId = nextNode and firstAudioPortId(nextNode.id, \"input\") or nil\n  if prevNode == nil or prevOutputPortId == nil then\n    return M.normalizeConnections(connections, rackNodes)\n  end\n\n  local working = M.spliceNode(connections, spliceNodes, nodeId)\n\n  if nextNode and nextInputPortId then\n    working = removeAudioConnectionsMatching(working, function(conn)\n      local toEndpoint = rawAudioEndpoint(conn, true)\n      return toEndpoint\n        and toEndpoint.nodeId == nextNode.id\n        and toEndpoint.portId == nextInputPortId\n    end)\n  else\n    working = removeAudioConnectionsMatching(working, function(conn)\n      local fromEndpoint = rawAudioEndpoint(conn, false)\n      local toEndpoint = rawAudioEndpoint(conn, true)\n      return fromEndpoint and toEndpoint\n        and fromEndpoint.nodeId == prevNode.id\n        and fromEndpoint.portId == prevOutputPortId\n        and toEndpoint.nodeId == M.OUTPUT_NODE_ID\n        and toEndpoint.portId == M.OUTPUT_PORT_ID\n    end)\n  end\n\n  working[#working + 1] = makeAudioConnectionFromEndpoints(\n    rackNodes,\n    { nodeId = prevNode.id, portId = prevOutputPortId },\n    { nodeId = nodeId, portId = nodeInputPortId },\n    tostring(prevNode.id) .. \"_to_\" .. tostring(nodeId),\n    { source = \"shift-insert\" }\n  )\n\n  if nextNode and nextInputPortId then\n    working[#working + 1] = makeAudioConnectionFromEndpoints(\n      rackNodes,\n      { nodeId = nodeId, portId = nodeOutputPortId },\n      { nodeId = nextNode.id, portId = nextInputPortId },\n      tostring(nodeId) .. \"_to_\" .. tostring(nextNode.id),\n      { source = \"shift-insert\" }\n    )\n  else\n    working[#working + 1] = makeAudioConnectionFromEndpoints(\n      rackNodes,\n      { nodeId = nodeId, portId = nodeOutputPortId },\n      { nodeId = M.OUTPUT_NODE_ID, portId = M.OUTPUT_PORT_ID },\n      tostring(nodeId) .. \"_to_output\",\n      { source = \"shift-insert\" }\n    )\n  end\n\n  return M.normalizeConnections(working, rackNodes)\nend\n\nreturn M\n"}],"isError":false,"timestamp":1775152589883}}
