{"type":"message","id":"90c68953","parentId":"391f49c9","timestamp":"2026-04-02T18:07:20.055Z","message":{"role":"toolResult","toolCallId":"tool_ykhOBnwNZimTnL3krs9XBKW0","toolName":"read","content":[{"type":"text","text":"end\n\nfunction M.normalizeConnections(connections, nodes)\n  local normalized = {}\n  local rackNodes = type(nodes) == \"table\" and RackLayout.cloneNodes(nodes) or M.defaultRackState().nodes\n  local nodeIdSet = buildNodeIdSet(rackNodes)\n  local source = type(connections) == \"table\" and connections or {}\n  local seenAudio = {}\n\n  for i = 1, #source do\n    local conn = source[i]\n    if isAllowedNonAudioConnection(conn) and connectionEndpointsExist(nodeIdSet, conn) then\n      normalized[#normalized + 1] = RackLayout.makeConnectionDescriptor(conn)\n    end\n  end\n\n  for i = 1, #source do\n    local conn = source[i]\n    if tostring(conn and conn.kind or \"\") == \"audio\" and connectionEndpointsExist(nodeIdSet, conn) then\n      local rawFrom = type(conn.from) == \"table\" and conn.from or nil\n      local rawTo = type(conn.to) == \"table\" and conn.to or nil\n      if rawFrom and rawTo then\n        local fromNodeId = tostring(rawFrom.nodeId or \"\")\n        local fromPortId = tostring(rawFrom.portId or \"\")\n        local toNodeId = tostring(rawTo.nodeId or \"\")\n        local toPortId = tostring(rawTo.portId or \"\")\n        local touchesRail = fromNodeId == \"__rackRail\" or toNodeId == \"__rackRail\"\n        local keep = false\n\n        if touchesRail then\n          keep = true\n        else\n          local supportedKey = table.concat({ fromNodeId, fromPortId, toNodeId, toPortId }, \":\")\n          keep = AUDIO_ROUTE_EDGE_INDEX[supportedKey] ~= nil\n            or (isGenericAudioEndpoint(fromNodeId, fromPortId, \"output\") and isGenericAudioEndpoint(toNodeId, toPortId, \"input\"))\n        end\n\n        if keep then\n          local dedupeKey = table.concat({ fromNodeId, fromPortId, toNodeId, toPortId }, \":\")\n          if not seenAudio[dedupeKey] then\n            local preferredId = type(conn.id) == \"string\" and conn.id ~= \"\" and conn.id or nil\n            local metaSource = type(conn.meta) == \"table\" and tostring(conn.meta.source or \"\") ~= \"\" and tostring(conn.meta.source) or \"current-ui\"\n            normalized[#normalized + 1] = makeConnection(\n              preferredId or (fromNodeId .. \"_to_\" .. toNodeId),\n              \"audio\",\n              fromNodeId,\n              fromPortId,\n              toNodeId,\n              toPortId,\n              decorateAudioMeta(rackNodes, fromNodeId, toNodeId, {\n                source = metaSource,\n              })\n            )\n            seenAudio[dedupeKey] = true\n          end\n        end\n      end\n    end\n  end\n\n  return normalized\nend\n\nfunction M.defaultConnections(nodes)\n  local rackNodes = type(nodes) == \"table\" and RackLayout.cloneNodes(nodes) or M.defaultRackState().nodes\n  return M.normalizeConnections({\n    makeConnection(\"adsr_to_oscillator\", \"control\", \"adsr\", \"env\", \"oscillator\", \"gate\", {\n      source = \"current-ui\",\n    }),\n    canonicalAudioConnection(rackNodes, \"oscillator_to_filter\"),\n    canonicalAudioConnection(rackNodes, \"filter_to_fx1\"),\n    canonicalAudioConnection(rackNodes, \"fx1_to_fx2\"),\n    canonicalAudioConnection(rackNodes, \"fx2_to_eq\"),\n    canonicalAudioConnection(rackNodes, \"eq_to_output\"),\n  }, rackNodes)\nend\n\nfunction M.hasConnection(connections, kind, fromNodeId, fromPortId, toNodeId, toPortId)\n  return hasConnectionEndpoints(connections, kind, fromNodeId, fromPortId, toNodeId, toPortId)\nend\n\n[490 more lines in file. Use offset=1045 to continue.]"}],"isError":false,"timestamp":1775153240051}}
