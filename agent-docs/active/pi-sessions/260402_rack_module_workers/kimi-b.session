tId },\n    to = { moduleId = toModuleId, portId = toPortId },\n    meta = meta or {},\n  }\nend"},{"oldText":"local function nodeRow(nodes, nodeId)\n  if type(nodes) ~= \"table\" then\n    return nil\n  end\n  for i = 1, #nodes do\n    local node = nodes[i]\n    if node and node.id == nodeId then\n      return math.max(0, math.floor(tonumber(node.row) or 0))\n    end\n  end\n  return nil\nend","newText":"local function moduleRow(modules, moduleId)\n  if type(modules) ~= \"table\" then\n    return nil\n  end\n  for i = 1, #modules do\n    local module = modules[i]\n    if module and module.id == moduleId then\n      return math.max(0, math.floor(tonumber(module.row) or 0))\n    end\n  end\n  return nil\nend"},{"oldText":"local function isRowWrapNeighbor(nodes, fromNodeId, toNodeId)\n  local ordered = RackLayout.getFlowNodes(type(nodes) == \"table\" and nodes or {})\n  local filtered = {}\n  for i = 1, #ordered do\n    local node = ordered[i]\n    if node and node.id ~= \"adsr\" then\n      filtered[#filtered + 1] = node\n    end\n  end\n\n  for i = 1, #filtered - 1 do\n    local a = filtered[i]\n    local b = filtered[i + 1]\n    if a and b and a.id == fromNodeId and b.id == toNodeId then\n      local fromRow = math.max(0, math.floor(tonumber(a.row) or 0))\n      local toRow = math.max(0, math.floor(tonumber(b.row) or 0))\n      return fromRow ~= toRow\n    end\n  end\n\n  return false\nend","newText":"local function isRowWrapNeighbor(modules, fromModuleId, toModuleId)\n  local ordered = RackLayout.getFlowModules(type(modules) == \"table\" and modules or {})\n  local filtered = {}\n  for i = 1, #ordered do\n    local module = ordered[i]\n    if module and module.id ~= \"adsr\" then\n      filtered[#filtered + 1] = module\n    end\n  end\n\n  for i = 1, #filtered - 1 do\n    local a = filtered[i]\n    local b = filtered[i + 1]\n    if a and b and a.id == fromModuleId and b.id == toModuleId then\n      local fromRow = math.max(0, math.floor(tonumber(a.row) or 0))\n      local toRow = math.max(0, math.floor(tonumber(b.row) or 0))\n      return fromRow ~= toRow\n    end\n  end\n\n  return false\nend"},{"oldText":"local function decorateAudioMeta(nodes, fromNodeId, toNodeId, extraMeta)\n  local meta = type(extraMeta) == \"table\" and deepCopy(extraMeta) or {}\n\n  if toNodeId == M.OUTPUT_NODE_ID then\n    meta.route = \"output\"\n  elseif isRowWrapNeighbor(nodes, fromNodeId, toNodeId) then\n    meta.route = \"relay\"\n  else\n    meta.route = nil\n  end\n\n  return meta\nend","newText":"local function decorateAudioMeta(modules, fromModuleId, toModuleId, extraMeta)\n  local meta = type(extraMeta) == \"table\" and deepCopy(extraMeta) or {}\n\n  if toModuleId == M.OUTPUT_NODE_ID then\n    meta.route = \"output\"\n  elseif isRowWrapNeighbor(modules, fromModuleId, toModuleId) then\n    meta.route = \"relay\"\n  else\n    meta.route = nil\n  end\n\n  return meta\nend"},{"oldText":"local function canonicalAudioConnection(nodes, id)\n  if id == \"oscillator_to_filter\" then\n    return makeConnection(id, \"audio\", \"oscillator\", \"out\", \"filter\", \"in\", decorateAudioMeta(nodes, \"oscillator\", \"filter\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"filter_to_fx1\" then\n    return makeConnection(id, \"audio\", \"filter\", \"out\", \"fx1\", \"in\", decorateAudioMeta(nodes, \"filter\", \"fx1\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx1_to_fx2\" then\n    return makeConnection(id, \"audio\", \"fx1\", \"out\", \"fx2\", \"in\", decorateAudioMeta(nodes, \"fx1\", \"fx2\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx2_to_eq\" then\n    return makeConnection(id, \"audio\", \"fx2\", \"out\", \"eq\", \"in\", decorateAudioMeta(nodes, \"fx2\", \"eq\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"eq_to_output\" then\n    return makeConnection(id, \"audio\", \"eq\", \"out\", M.OUTPUT_NODE_ID, M.OUTPUT_PORT_ID, decorateAudioMeta(nodes, \"eq\", M.OUTPUT_NODE_ID, {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx2_to_output\" then\n    return makeConnection(id, \"audio\", \"fx2\", \"out\", M.OUTPUT_NODE_ID, M.OUTPUT_PORT_ID, decorateAudioMeta(nodes, \"fx2\", M.OUTPUT_NODE_ID, {\n      source = \"fixed-dsp-chain\",\n    }))\n  end\n  return nil\nend","newText":"local function canonicalAudioConnection(modules, id)\n  if id == \"oscillator_to_filter\" then\n    return makeConnection(id, \"audio\", \"oscillator\", \"out\", \"filter\", \"in\", decorateAudioMeta(modules, \"oscillator\", \"filter\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"filter_to_fx1\" then\n    return makeConnection(id, \"audio\", \"filter\", \"out\", \"fx1\", \"in\", decorateAudioMeta(modules, \"filter\", \"fx1\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx1_to_fx2\" then\n    return makeConnection(id, \"audio\", \"fx1\", \"out\", \"fx2\", \"in\", decorateAudioMeta(modules, \"fx1\", \"fx2\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx2_to_eq\" then\n    return makeConnection(id, \"audio\", \"fx2\", \"out\", \"eq\", \"in\", decorateAudioMeta(modules, \"fx2\", \"eq\", {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"eq_to_output\" then\n    return makeConnection(id, \"audio\", \"eq\", \"out\", M.OUTPUT_NODE_ID, M.OUTPUT_PORT_ID, decorateAudioMeta(modules, \"eq\", M.OUTPUT_NODE_ID, {\n      source = \"fixed-dsp-chain\",\n    }))\n  elseif id == \"fx2_to_output\" then\n    return makeConnection(id, \"audio\", \"fx2\", \"out\", M.OUTPUT_NODE_ID, M.OUTPUT_PORT_ID, decorateAudioMeta(modules, \"fx2\", M.OUTPUT_NODE_ID, {\n      source = \"fixed-dsp-chain\",\n    }))\n  end\n  return nil\nend"},{"oldText":"local function buildNodeIdSet(nodes)\n  local out = {}\n  if type(nodes) ~= \"table\" then\n    return out\n  end\n  for i = 1, #nodes do\n    local node = nodes[i]\n    local nodeId = node and tostring(node.id or \"\") or \"\"\n    if nodeId ~= \"\" then\n      out[nodeId] = true\n    end\n  end\n  return out\nend","newText":"local function buildModuleIdSet(modules)\n  local out = {}\n  if type(modules) ~= \"table\" then\n    return out\n  end\n  for i = 1, #modules do\n    local module = modules[i]\n    local moduleId = module and tostring(module.id or \"\") or \"\"\n    if moduleId ~= \"\" then\n      out[moduleId] = true\n    end\n  end\n  return out\nend"},{"oldText":"local function endpointNodeExists(nodeIdSet, nodeId)\n  local id = tostring(nodeId or \"\")\n  return id == \"__rackRail\" or id == M.OUTPUT_NODE_ID or nodeIdSet[id] == true\nend","newText":"local function endpointModuleExists(moduleIdSet, moduleId)\n  local id = tostring(moduleId or \"\")\n  return id == \"__rackRail\" or id == M.OUTPUT_NODE_ID or moduleIdSet[id] == true\nend"},{"oldText":"local function connectionEndpointsExist(nodeIdSet, conn)\n  local from = type(conn) == \"table\" and conn.from or nil\n  local to = type(conn) == \"table\" and conn.to or nil\n  return type(from) == \"table\"\n    and type(to) == \"table\"\n    and endpointNodeExists(nodeIdSet, from.nodeId)\n    and endpointNodeExists(nodeIdSet, to.nodeId)\nend","newText":"local function connectionEndpointsExist(moduleIdSet, conn)\n  local from = type(conn) == \"table\" and conn.from or nil\n  local to = type(conn) == \"table\" and conn.to or nil\n  return type(from) == \"table\"\n    and type(to) == \"table\"\n    and endpointModuleExists(moduleIdSet, from.moduleId)\n    and endpointModuleExists(moduleIdSet, to.moduleId)\nend"},{"oldText":"local function isRailOutputTarget(conn)\n  local to = type(conn) == \"table\" and conn.to or nil\n  return type(to) == \"table\"\n    and tostring(to.nodeId or \"\") == \"__rackRail\"\n    and tostring(to.portId or \"\"):match(\"^send_row%d+$\") ~= nil\nend","newText":"local function isRailOutputTarget(conn)\n  local to = type(conn) == \"table\" and conn.to or nil\n  return type(to) == \"table\"\n    and tostring(to.moduleId or \"\") == \"__rackRail\"\n    and tostring(to.portId or \"\"):match(\"^send_row%d+$\") ~= nil\nend"},{"oldText":"local function isGenericAudioEndpoint(nodeId, portId, direction)\n  local id = tostring(nodeId or \"\")\n  local pid = tostring(portId or \"\")\n  if id == M.OUTPUT_NODE_ID then\n    return direction == \"input\" and pid == M.OUTPUT_PORT_ID\n  end\n  if id == \"__rackRail\" then\n    if direction == \"input\" then\n      return pid:match(\"^recv_row%d+$\") ~= nil\n    end\n    return pid:match(\"^send_row%d+$\") ~= nil\n  end\n  local expected = firstAudioPortId(id, direction)\n  return expected ~= nil and pid == expected\nend","newText":"local function isGenericAudioEndpoint(moduleId, portId, direction)\n  local id = tostring(moduleId or \"\")\n  local pid = tostring(portId or \"\")\n  if id == M.OUTPUT_NODE_ID then\n    return direction == \"input\" and pid == M.OUTPUT_PORT_ID\n  end\n  if id == \"__rackRail\" then\n    if direction == \"input\" then\n      return pid:match(\"^recv_row%d+$\") ~= nil\n    end\n    return pid:match(\"^send_row%d+$\") ~= nil\n  end\n  local expected = firstAudioPortId(id, direction)\n  return expected ~= nil and pid == expected\nend"},{"oldText":"local function hasConnectionEndpoints(connections, kind, fromNodeId, fromPortId, toNodeId, toPortId)\n  if type(connections) ~= \"table\" then\n    return false\n  end\n  for i = 1, #connections do\n    local conn = connections[i]\n    local from = type(conn) == \"table\" and conn.from or nil\n    local to = type(conn) == \"table\" and conn.to or nil\n    if tostring(conn and conn.kind or \"\") == tostring(kind or \"\")\n      and type(from) == \"table\"\n      and type(to) == \"table\"\n      and tostring(from.nodeId or \"\") == tostring(fromNodeId or \"\")\n      and tostring(from.portId or \"\") == tostring(fromPortId or \"\")\n      and tostring(to.nodeId or \"\") == tostring(toNodeId or \"\")\n      and tostring(to.portId or \"\") == tostring(toPortId or \"\") then\n      return true\n    end\n  end\n  return false\nend","newText":"local function hasConnectionEndpoints(connections, kind, fromModuleId, fromPortId, toModuleId, toPortId)\n  if type(connections) ~= \"table\" then\n    return false\n  end\n  for i = 1, #connections do\n    local conn = connections[i]\n    local from = type(conn) == \"table\" and conn.from or nil\n    local to = type(conn) == \"table\" and conn.to or nil\n    if tostring(conn and conn.kind or \"\") == tostring(kind or \"\")\n      and type(from) == \"table\"\n      and type(to) == \"table\"\n      and tostring(from.moduleId or \"\") == tostring(fromModuleId or \"\")\n      and tostring(from.portId or \"\") == tostring(fromPortId or \"\")\n      and tostring(to.moduleId or \"\") == tostring(toModuleId or \"\")\n      and tostring(to.portId or \"\") == tostring(toPortId or \"\") then\n      return true\n    end\n  end\n  return false\nend"},{"oldText":"local function buildFlowOrder(nodes)\n  local ordered = RackLayout.getFlowNodes(type(nodes) == \"table\" and nodes or {})\n  local order = {}\n  local index = 0\n  for i = 1, #ordered do\n    local node = ordered[i]\n    if node and node.id ~= \"adsr\" then\n      index = index + 1\n      order[node.id] = index\n    end\n  end\n  return order, index\nend","newText":"local function buildFlowOrder(modules)\n  local ordered = RackLayout.getFlowModules(type(modules) == \"table\" and modules or {})\n  local order = {}\n  local index = 0\n  for i = 1, #ordered do\n    local module = ordered[i]\n    if module and module.id ~= \"adsr\" then\n      index = index + 1\n      order[module.id] = index\n    end\n  end\n  return order, index\nend"},{"oldText":"local function canonicalizeAudioEndpoint(conn, isTarget)\n  local endpoint = isTarget and conn.to or conn.from\n  if type(endpoint) ~= \"table\" then\n    return nil\n  end\n  local nodeId = tostring(endpoint.nodeId or \"\")\n  local portId = tostring(endpoint.portId or \"\")\n  if isTarget and (nodeId == M.OUTPUT_NODE_ID or isRailOutputTarget(conn)) then\n    return {\n      nodeId = M.OUTPUT_NODE_ID,\n      portId = M.OUTPUT_PORT_ID,\n    }\n  end\n  if nodeId == \"__rackRail\" then\n    return nil\n  end\n  return {\n    nodeId = nodeId,\n    portId = portId,\n  }\nend","newText":"local function canonicalizeAudioEndpoint(conn, isTarget)\n  local endpoint = isTarget and conn.to or conn.from\n  if type(endpoint) ~= \"table\" then\n    return nil\n  end\n  local moduleId = tostring(endpoint.moduleId or \"\")\n  local portId = tostring(endpoint.portId or \"\")\n  if isTarget and (moduleId == M.OUTPUT_NODE_ID or isRailOutputTarget(conn)) then\n    return {\n      moduleId = M.OUTPUT_NODE_ID,\n      portId = M.OUTPUT_PORT_ID,\n    }\n  end\n  if moduleId == \"__rackRail\" then\n    return nil\n  end\n  return {\n    moduleId = moduleId,\n    portId = portId,\n  }\nend"},{"oldText":"local function rawAudioEndpoint(conn, isTarget)\n  local endpoint = isTarget and conn.to or conn.from\n  if type(endpoint) ~= \"table\" then\n    return nil\n  end\n\n  local nodeId = tostring(endpoint.nodeId or \"\")\n  local portId = tostring(endpoint.portId or \"\")\n  if nodeId == \"\" or portId == \"\" then\n    return nil\n  end\n\n  return {\n    nodeId = nodeId,\n    portId = portId,\n  }\nend","newText":"local function rawAudioEndpoint(conn, isTarget)\n  local endpoint = isTarget and conn.to or conn.from\n  if type(endpoint) ~= \"table\" then\n    return nil\n  end\n\n  local moduleId = tostring(endpoint.moduleId or \"\")\n  local portId = tostring(endpoint.portId or \"\")\n  if moduleId == \"\" or portId == \"\" then\n    return nil\n  end\n\n  return {\n    moduleId = moduleId,\n    portId = portId,\n  }\nend"},{"oldText":"local function makeAudioConnectionFromEndpoints(nodes, fromEndpoint, toEndpoint, preferredId, extraMeta)\n  if type(fromEndpoint) ~= \"table\" or type(toEndpoint) ~= \"table\" then\n    return nil\n  end\n  return makeConnection(\n    preferredId or (tostring(fromEndpoint.nodeId) .. \"_to_\" .. tostring(toEndpoint.nodeId)),\n    \"audio\",\n    fromEndpoint.nodeId,\n    fromEndpoint.portId,\n    toEndpoint.nodeId,\n    toEndpoint.portId,\n    decorateAudioMeta(nodes, fromEndpoint.nodeId, toEndpoint.nodeId, extraMeta)\n  )\nend","newText":"local function makeAudioConnectionFromEndpoints(modules, fromEndpoint, toEndpoint, preferredId, extraMeta)\n  if type(fromEndpoint) ~= \"table\" or type(toEndpoint) ~= \"table\" then\n    return nil\n  end\n  return makeConnection(\n    preferredId or (tostring(fromEndpoint.moduleId) .. \"_to_\" .. tostring(toEndpoint.moduleId)),\n    \"audio\",\n    fromEndpoint.moduleId,\n    fromEndpoint.portId,\n    toEndpoint.moduleId,\n    toEndpoint.portId,\n    decorateAudioMeta(modules, fromEndpoint.moduleId, toEndpoint.moduleId, extraMeta)\n  )\nend"},{"oldText":"local function findNodeSpec(nodeId)\n  local id = tostring(nodeId or \"\")\n  local dynamicSpecs = type(_G) == \"table\" and _G.__midiSynthDynamicNodeSpecs or nil\n  if type(dynamicSpecs) == \"table\" and dynamicSpecs[id] ~= nil then\n    return dynamicSpecs[id]\n  end\n  for i = 1, #NODE_SPECS do\n    local spec = NODE_SPECS[i]\n    if spec and spec.id == id then\n      return spec\n    end\n  end\n  return nil\nend","newText":"local function findModuleSpec(moduleId)\n  local id = tostring(moduleId or \"\")\n  local dynamicSpecs = type(_G) == \"table\" and _G.__midiSynthDynamicModuleSpecs or nil\n  if type(dynamicSpecs) == \"table\" and dynamicSpecs[id] ~= nil then\n    return dynamicSpecs[id]\n  end\n  for i = 1, #RACK_MODULE_SPECS do\n    local spec = RACK_MODULE_SPECS[i]\n    if spec and spec.id == id then\n      return spec\n    end\n  end\n  return nil\nend"},{"oldText":"firstAudioPortId = function(nodeId, direction)\n  local spec = findNodeSpec(nodeId)\n  local ports = spec and spec.ports or nil\n  local list = nil\n  if direction == \"input\" then\n    list = ports and ports.inputs or nil\n  else\n    list = ports and ports.outputs or nil\n  end\n  if type(list) ~= \"table\" then\n    return nil\n  end\n  for i = 1, #list do\n    local port = list[i]\n    if port and tostring(port.type or \"\") == \"audio\" then\n      return tostring(port.id or \"\")\n    end\n  end\n  return nil\nend","newText":"firstAudioPortId = function(moduleId, direction)\n  local spec = findModuleSpec(moduleId)\n  local ports = spec and spec.ports or nil\n  local list = nil\n  if direction == \"input\" then\n    list = ports and ports.inputs or nil\n  else\n    list = ports and ports.outputs or nil\n  end\n  if type(list) ~= \"table\" then\n    return nil\n  end\n  for i = 1, #list do\n    local port = list[i]\n    if port and tostring(port.type or \"\") == \"audio\" then\n      return tostring(port.id or \"\")\n    end\n  end\n  return nil\nend"},{"oldText":"local function isTransparentAudioNode(nodeId)\n  local spec = findNodeSpec(nodeId)\n  local meta = spec and spec.meta or nil\n  return type(meta) == \"table\" and meta.audioPassthrough == true\nend","newText":"local function isTransparentAudioModule(moduleId)\n  local spec = findModuleSpec(moduleId)\n  local meta = spec and spec.meta or nil\n  return type(meta) == \"table\" and meta.audioPassthrough == true\nend"},{"oldText":"local function isRealAudioStageNode(nodeId)\n  local id = tostring(nodeId or \"\")\n  if id == \"\" or id == \"adsr\" or id == M.OUTPUT_NODE_ID or id == \"__rackRail\" then\n    return false\n  end\n  if isTransparentAudioNode(id) then\n    return false\n  end\n  return firstAudioPortId(id, \"input\") ~= nil or firstAudioPortId(id, \"output\") ~= nil\nend","newText":"local function isRealAudioStageModule(moduleId)\n  local id = tostring(moduleId or \"\")\n  if id == \"\" or id == \"adsr\" or id == M.OUTPUT_NODE_ID or id == \"__rackRail\" then\n    return false\n  end\n  if isTransparentAudioModule(id) then\n    return false\n  end\n  return firstAudioPortId(id, \"input\") ~= nil or firstAudioPortId(id, \"output\") ~= nil\nend"},{"oldText":"local function orderedAudioFlowNodes(nodes)\n  local ordered = RackLayout.getFlowNodes(type(nodes) == \"table\" and nodes or {})\n  local out = {}\n  for i = 1, #ordered do\n    local node = ordered[i]\n    if node and node.id ~= \"adsr\" then\n      local hasInput = firstAudioPortId(node.id, \"input\") ~= nil\n      local hasOutput = firstAudioPortId(node.id, \"output\") ~= nil\n      if hasInput or hasOutput then\n        out[#out + 1] = node\n      end\n    end\n  end\n  return out\nend","newText":"local function orderedAudioFlowModules(modules)\n  local ordered = RackLayout.getFlowModules(type(modules) == \"table\" and modules or {})\n  local out = {}\n  for i = 1, #ordered do\n    local module = ordered[i]\n    if module and module.id ~= \"adsr\" then\n      local hasInput = firstAudioPortId(module.id, \"input\") ~= nil\n      local hasOutput = firstAudioPortId(module.id, \"output\") ~= nil\n      if hasInput or hasOutput then\n        out[#out + 1] = module\n      end\n    end\n  end\n  return out\nend"},{"oldText":"function M.defaultRackState()\n  local state = RackLayout.defaultRackState()\n  state.nodes = {\n    RackLayout.makeNodeInstance { id = \"adsr\", row = 0, col = 0, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"envelopeComponent\" } },\n    RackLayout.makeNodeInstance { id = \"oscillator\", row = 0, col = 1, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"oscillatorComponent\" } },\n    RackLayout.makeNodeInstance { id = \"filter\", row = 0, col = 3, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"filterComponent\" } },\n    RackLayout.makeNodeInstance { id = \"fx1\", row = 1, col = 0, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"fx1Component\" } },\n    RackLayout.makeNodeInstance { id = \"fx2\", row = 1, col = 2, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"fx2Component\" } },\n    RackLayout.makeNodeInstance { id = \"eq\", row = 1, col = 4, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"eqComponent\" } },\n    RackLayout.makeNodeInstance { id = \"placeholder1\", row = 2, col = 0, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"placeholder1Content\" } },\n    RackLayout.makeNodeInstance { id = \"placeholder2\", row = 2, col = 2, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"placeholder2Content\" } },\n    RackLayout.makeNodeInstance { id = \"placeholder3\", row = 2, col = 4, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"placeholder3Content\" } },\n  }\n  return state\nend","newText":"function M.defaultRackState()\n  local state = RackLayout.defaultRackState()\n  state.modules = {\n    RackLayout.makeRackModuleInstance { id = \"adsr\", row = 0, col = 0, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"envelopeComponent\" } },\n    RackLayout.makeRackModuleInstance { id = \"oscillator\", row = 0, col = 1, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"oscillatorComponent\" } },\n    RackLayout.makeRackModuleInstance { id = \"filter\", row = 0, col = 3, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"filterComponent\" } },\n    RackLayout.makeRackModuleInstance { id = \"fx1\", row = 1, col = 0, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"fx1Component\" } },\n    RackLayout.makeRackModuleInstance { id = \"fx2\", row = 1, col = 2, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"fx2Component\" } },\n    RackLayout.makeRackModuleInstance { id = \"eq\", row = 1, col = 4, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"eqComponent\" } },\n    RackLayout.makeRackModuleInstance { id = \"placeholder1\", row = 2, col = 0, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"placeholder1Content\" } },\n    RackLayout.makeRackModuleInstance { id = \"placeholder2\", row = 2, col = 2, w = 2, h = 1, sizeKey = \"1x2\", meta = { componentId = \"placeholder2Content\" } },\n    RackLayout.makeRackModuleInstance { id = \"placeholder3\", row = 2, col = 4, w = 1, h = 1, sizeKey = \"1x1\", meta = { componentId = \"placeholder3Content\" } },\n  }\n  return state\nend"}]}}],"api":"anthropic-messages","provider":"kimi-coding-plan","model":"kimi-for-coding","usage":{"input":2105,"output":8092,"cacheRead":25600,"cacheWrite":0,"totalTokens":35797,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775152589887,"responseId":"msg_m1rUsg8455lnuOlyXzsijNLM"}}
