eId)\n  local rackState = ctx and ctx._rackState or nil\n  local modules = rackState and rackState.modules or nil\n  if type(modules) ~= \"table\" then\n    return nil\n  end\n  for i = 1, #modules do\n    local module = modules[i]\n    if module and module.id == moduleId then\n      return math.max(0, math.floor(tonumber(module.row) or 0))\n    end\n  end\n  return nil\nend"}]}}],"api":"anthropic-messages","provider":"kimi-coding-plan","model":"kimi-for-coding","usage":{"input":1051,"output":602,"cacheRead":58112,"cacheWrite":0,"totalTokens":59765,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1775152708744,"responseId":"msg_xBzQ222uhO5DJ2wM1L2dtKGh"}}
