e(nextNodes) ~= \"table\" then\n    if unregisterOnFailure then\n      M._unregisterDynamicNodeSpec(ctx, nodeId)\n    end\n    return false\n  end\n\n  ctx._rackState.nodes = RackLayout.cloneNodes(nextNodes)\n  ctx._rackState.utilityDock = ensureUtilityDockState(ctx)\n  local shouldInsertWire = (insertMode == true) or (tonumber(insertMode) or 0) > 0.5\n  local nextConnections\n  if shouldInsertWire then\n    nextConnections = MidiSynthRackSpecs.insertNodeAtVisualSlot(\n      ctx._rackConnections or {},\n      ctx._rackState.nodes,\n      nodeId,\n      baseNodes\n    )\n  else\n    nextConnections = MidiSynthRackSpecs.normalizeConnections(ctx._rackConnections or {}, ctx._rackState.nodes)\n  end\n  local topologyChanged = shouldInsertWire or (type(M._rackTopologyChanged) == \"function\" and M._rackTopologyChanged(previousConnections, previousNodes, nextConnections, ctx._rackState.nodes) == true)\n  ctx._rackConnections = nextConnections\n  _G.__midiSynthRackState = ctx._rackState\n  _G.__midiSynthRackConnections = ctx._rackConnections\n\n  if topologyChanged then\n    applyRackConnectionState(ctx, shouldInsertWire and \"palette-spawn-insert\" or \"palette-spawn\")\n    refreshManagedLayoutState(ctx, ctx._lastW, ctx._lastH)\n\n[1945 more lines in file. Use offset=2720 to continue.]"}],"isError":false,"timestamp":1775153512456}}
